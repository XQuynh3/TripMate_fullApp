<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Swipe/Delete background -->
    <LinearLayout
        android:id="@+id/deleteLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="end|center_vertical"
        android:background="@color/tripmate_error"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/deleteIcon"
            android:text="🗑"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0F2F1"
        app:cardBackgroundColor="@color/tripmate_card">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?attr/selectableItemBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/title"
                    android:text="Note title"
                    android:textColor="@color/tripmate_text"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content" />

                <ImageView
                    android:id="@+id/shareBtn"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:tint="@color/tripmate_primary"
                    android:contentDescription="Share"
                    android:padding="7dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:id="@+id/deleteBtn"
                    android:text="⋮"
                    android:textSize="22sp"
                    android:textColor="@color/tripmate_text_secondary"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="34dp"
                    android:layout_height="34dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/content"
                android:text="Note content"
                android:textColor="@color/tripmate_text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tag"
                android:text="Category"
                android:textColor="@color/tripmate_primary"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Location"
                android:textColor="@color/tripmate_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/time"
                android:text="Updated recently"
                android:textColor="@color/tripmate_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>