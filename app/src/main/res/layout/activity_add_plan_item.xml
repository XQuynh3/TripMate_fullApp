<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tripmate_background"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="← Back"
            android:textColor="@color/tripmate_primary"
            android:textStyle="bold"
            android:textAllCaps="false"
                android:letterSpacing="0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvTitle"
            android:text="Add Plan Item"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Title"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="false"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/tripmate_card"
            app:boxStrokeColor="@color/tripmate_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Visit museum"
                android:inputType="text"
                android:textColor="@color/tripmate_text"
                android:textColorHint="@color/tripmate_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:text="Note"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="false"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/tripmate_card"
            app:boxStrokeColor="@color/tripmate_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Optional details"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:textColor="@color/tripmate_text"
                android:textColorHint="@color/tripmate_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:text="Type"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llTypeChips"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </HorizontalScrollView>

        <TextView
            android:text="Start Time"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="false"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/tripmate_card"
            app:boxStrokeColor="@color/tripmate_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStartTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select start time"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:textColor="@color/tripmate_text"
                android:textColorHint="@color/tripmate_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:text="End Time (optional)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="false"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/tripmate_card"
            app:boxStrokeColor="@color/tripmate_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEndTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select end time"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:textColor="@color/tripmate_text"
                android:textColorHint="@color/tripmate_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:text="Location Name (optional)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintEnabled="false"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/tripmate_card"
            app:boxStrokeColor="@color/tripmate_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLocationName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Louvre Museum"
                android:inputType="text"
                android:textColor="@color/tripmate_text"
                android:textColorHint="@color/tripmate_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:text="Assigned To (optional)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llMemberChips"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:text="Save"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textAllCaps="false"
                android:letterSpacing="0"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            app:cornerRadius="25dp"
            android:backgroundTint="@color/tripmate_primary" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
