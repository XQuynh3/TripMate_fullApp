<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tripmate_background"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top Bar -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:text="← Back"
                android:textColor="@color/tripmate_primary"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:letterSpacing="0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditTrip"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="Edit"
                android:textColor="@color/tripmate_primary"
                android:textAllCaps="false"
                android:letterSpacing="0"
                app:strokeColor="@color/tripmate_primary"
                app:cornerRadius="18dp"
                android:layout_width="wrap_content"
                android:layout_height="40dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:text="Refresh"
                android:textColor="@color/tripmate_text_secondary"
                android:textAllCaps="false"
                android:letterSpacing="0"
                android:layout_marginStart="4dp"
                android:layout_width="wrap_content"
                android:layout_height="40dp" />
        </LinearLayout>

        <!-- Hero Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/tripmate_primary">

            <LinearLayout
                android:orientation="vertical"
                android:padding="22dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvTitle"
                    android:text="Trip Title"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvDestination"
                    android:text="Destination"
                    android:textSize="15sp"
                    android:textColor="#DDF7F3"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvNote"
                    android:text="Note..."
                    android:textSize="14sp"
                    android:textColor="#EAFDFB"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:text="planning"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/tripmate_primary"
                        android:background="@color/white"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEndTrip"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:text="End Trip"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                android:letterSpacing="0"
                        android:layout_marginStart="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOwner"
                    android:text="Owner: ..."
                    android:textSize="12sp"
                    android:textColor="#DDF7F3"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvMembers"
                    android:text="Members: ..."
                    android:textSize="12sp"
                    android:textColor="#DDF7F3"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvUpdatedBy"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#B9EFE8"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Invite Code Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInviteCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/tripmate_card"
            android:visibility="gone">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Invite Code"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/tripmate_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Share this code with friends. They need owner approval to join."
                        android:textSize="11sp"
                        android:textColor="@color/tripmate_text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvInviteCode"
                        android:text="---"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/tripmate_primary"
                        android:layout_marginTop="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopyInviteCode"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:text="Copy"
                    android:textSize="12sp"
                    android:textColor="@color/tripmate_primary"
                    android:textAllCaps="false"
                android:letterSpacing="0"
                    app:cornerRadius="18dp"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:textColor="@color/tripmate_error"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Notes / Plan Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/tripmate_card">

            <LinearLayout
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Trip Schedule"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Notes, checklist and daily plan items"
                    android:textSize="13sp"
                    android:textColor="@color/tripmate_text_secondary"
                    android:layout_marginTop="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Tab Toggle -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabNotes"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:text="Notes"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                android:letterSpacing="0"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="40dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTabPlan"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:text="Plan"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                android:letterSpacing="0"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="40dp" />
                </LinearLayout>

                <!-- Notes Section -->
                <LinearLayout
                    android:id="@+id/sectionNotes"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvChecklistProgress"
                        android:text="0 / 0 done"
                        android:textSize="13sp"
                        android:textColor="@color/tripmate_primary"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/llFilterChips"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </HorizontalScrollView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvChecklist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddTask"
                        android:text="＋ Add Note"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                android:letterSpacing="0"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="25dp"
                        android:backgroundTint="@color/tripmate_primary" />
                </LinearLayout>

                <!-- Plan Section -->
                <LinearLayout
                    android:id="@+id/sectionPlan"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvPlanEmpty"
                        android:text="No plan items yet. Generate or add manually."
                        android:textSize="13sp"
                        android:textColor="@color/tripmate_text_secondary"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvPlanItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGeneratePlan"
                        android:text="✨ Generate Plan"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                android:letterSpacing="0"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="25dp"
                        android:backgroundTint="@color/tripmate_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddPlanItem"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:text="＋ Add Plan Item"
                        android:textColor="@color/tripmate_primary"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                android:letterSpacing="0"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="25dp"
                        app:strokeColor="@color/tripmate_primary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Places Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/tripmate_card">

            <LinearLayout
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Places to visit"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Tap a place to view community rating, or press ＋ to add it as a note"
                    android:textSize="12sp"
                    android:textColor="@color/tripmate_text_secondary"
                    android:layout_marginTop="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPlaces"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingEnd="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Foods Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/tripmate_card">

            <LinearLayout
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Food to try"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Save food ideas to your notes and check ratings from other users"
                    android:textSize="12sp"
                    android:textColor="@color/tripmate_text_secondary"
                    android:layout_marginTop="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFoods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingEnd="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Active Reminders Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/tripmate_card">

            <LinearLayout
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Active Reminders"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Location reminders attached to your trip notes"
                    android:textSize="12sp"
                    android:textColor="@color/tripmate_text_secondary"
                    android:layout_marginTop="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:id="@+id/llActiveReminders"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Rating Section - hidden by default, kept for binding compatibility -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/tripmate_card">

            <LinearLayout
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Rate this trip"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Place name"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:hintEnabled="false"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/tripmate_card"
                    app:boxStrokeColor="@color/tripmate_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRatingPlace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter place name"
                        android:inputType="text"
                        android:textColor="@color/tripmate_text"
                        android:textColorHint="@color/tripmate_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:text="Score (1-5)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScore1"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:text="1"
                        android:textColor="@color/tripmate_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScore2"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:text="2"
                        android:textColor="@color/tripmate_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScore3"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:text="3"
                        android:textColor="@color/tripmate_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScore4"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:text="4"
                        android:textColor="@color/tripmate_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScore5"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:text="5"
                        android:textColor="@color/tripmate_primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>

                <TextView
                    android:text="Comment"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:hintEnabled="false"
                    app:boxBackgroundMode="outline"
                    app:boxBackgroundColor="@color/tripmate_card"
                    app:boxStrokeColor="@color/tripmate_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRatingComment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Write a short review"
                        android:inputType="text"
                        android:textColor="@color/tripmate_text"
                        android:textColorHint="@color/tripmate_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitRating"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:text="Submit Rating"
                    android:textAllCaps="false"
                android:letterSpacing="0"
                    app:cornerRadius="25dp"
                    android:backgroundTint="@color/tripmate_primary" />

                <TextView
                    android:text="Community Rating"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_text"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:id="@+id/llRatingSummary"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="28dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>