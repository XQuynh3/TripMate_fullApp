<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tripmate_background"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Destination Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/tripmate_card">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvBadge"
                    android:text="Smart Suggestion"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:background="@color/tripmate_accent"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvDestination"
                    android:text="Destination"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/tripmate_primary"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvIntro"
                    android:text="Intro..."
                    android:textSize="14sp"
                    android:textColor="@color/tripmate_text_secondary"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone"/>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:textColor="@color/tripmate_error"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Places -->
        <TextView
            android:text="Places to visit"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingEnd="8dp"/>

        <!-- Foods -->
        <TextView
            android:text="Food to try"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFoods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingEnd="8dp"/>

        <!-- Checklist -->
        <TextView
            android:text="Auto checklist"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/tripmate_text"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Choose items to include in your trip"
            android:textSize="13sp"
            android:textColor="@color/tripmate_text_secondary"
            android:layout_marginTop="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChecklist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"/>

        <!-- Create Trip Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateTrip"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Create Trip Plan"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            android:backgroundTint="@color/tripmate_primary"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
